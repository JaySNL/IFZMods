{
  "name": "ifzmods-nexus-publish",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Playwright pipeline to bulk-create IFZMods Nexus pages.",
  "scripts": {
    "upload": "node nexus-upload.mjs add auto",
    "page:login": "node publish.mjs --login-only",
    "page:create": "node publish.mjs --create",
    "page:dry-run": "node publish.mjs --create --dry-run"
  },
  "dependencies": {
    "playwright": "^1.49.0"
  }
}
